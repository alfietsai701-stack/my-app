generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id           String        @id @default(cuid())
  name         String
  phone        String        @unique
  email        String?
  lineUserId   String?       @unique
  birthday     DateTime?
  note         String?
  createdAt    DateTime      @default(now())
  deletedAt    DateTime?
  appointments Appointment[]
  member       Member?
}

model Service {
  id           String        @id @default(cuid())
  name         String
  price        Int
  durationMin  Int
  category     String
  appointments Appointment[]

  @@index([category])
}

model Appointment {
  id          String    @id @default(cuid())
  customerId  String
  serviceId   String
  scheduledAt DateTime
  status      String    @default("confirmed")
  note        String?
  createdAt   DateTime  @default(now())
  customer    Customer  @relation(fields: [customerId], references: [id])
  service     Service   @relation(fields: [serviceId], references: [id])
  receipt     Receipt?

  @@index([scheduledAt, status])
  @@index([customerId])
}

model Receipt {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  total         Int
  payMethod     String
  paidAt        DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model InventoryItem {
  id         String  @id @default(cuid())
  name       String
  brand      String?
  category   String  @default("其他")
  quantity   Int
  alertLevel Int
  unit       String
  note       String?
}

model Member {
  id         String   @id @default(cuid())
  customerId String   @unique
  tier       String   @default("general")
  points     Int      @default(0)
  joinedAt   DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
}

model StockCheckSession {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  completedAt DateTime?
  note        String?
  entries     StockCheckEntry[]
}

model StockCheckEntry {
  id        String             @id @default(cuid())
  sessionId String
  itemId    String
  itemName  String
  unit      String
  expected  Int
  actual    Int
  session   StockCheckSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Setting {
  key   String @id
  value Json
}

model LineSession {
  lineUserId String   @id
  step       String   @default("START")
  data       Json     @default("{}")
  updatedAt  DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  permissions  Json     @default("{}")
  createdAt    DateTime @default(now())
}